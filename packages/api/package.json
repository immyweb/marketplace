{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "bun run --filter @marketplace/core build",
    "dev": "bun --watch index.ts",
    "prebuild": "bun run --filter @marketplace/core build",
    "build": "tsc && tsc-alias",
    "pretest": "bun run --filter @marketplace/core build",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:migrate:test": "DATABASE_URL=$DATABASE_URL_TEST prisma migrate deploy",
    "db:seed": "bun run prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@marketplace/core": "*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "better-auth": "^1.6.23",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "express-session": "^1.18.0",
    "openai": "^6.0.0",
    "pg": "^8.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.8",
    "resend": "^6.17.1",
    "stripe": "^22.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.0.0",
    "msw": "^2.14.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.0.0",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
